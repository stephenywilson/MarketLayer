# MarketLayer by Catalayer — environment configuration
# Copy this file to `.env` and fill in the values for your chosen AI provider.
#
# MarketLayer requires a real AI provider to generate market reports.
# For a free local setup: install Ollama (https://ollama.com) and set AI_PROVIDER=ollama.
# For cloud providers: set the corresponding API key below.
# No API key is generated, stored, sold, or distributed by this repository.

# ----- AI Provider (required) -----
# Options: ollama | openai | anthropic | gemini | catalayer
# Use ollama for a fully local, free setup — no API key required.
AI_PROVIDER=ollama

# ----- Catalayer AI (optional subscription) -----
# Requires a Catalayer-issued subscription key. Get access at https://catalayer.com
# This repository does not generate, validate, or distribute Catalayer keys.
CATALAYER_API_KEY=
# Optional: leave empty unless you have official Catalayer API access.
CATALAYER_API_BASE_URL=

# ----- OpenAI-compatible -----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ----- Anthropic -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ----- Gemini -----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ----- Ollama (local, no API key required) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# ----- Catalayer AI Mini 500M (future local model, placeholder) -----
MINI500M_MODEL_PATH=./models/catalayer-ai-mini-500m

# ----- Server -----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
